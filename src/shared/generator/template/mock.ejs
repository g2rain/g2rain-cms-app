/**
 * <%= table.title %>相关 Mock 数据
 */

import type { AxiosRequestConfig } from 'axios';
import type { MockDataMap } from '@/components/http/mock-data';
import type { Result } from '@/components/http/types';
import Mock from 'mockjs';
import { mockManager } from '@/components/http/mock-data';

/**
 * 生成符合 Result 格式的响应
 */
function createResult<T>(data: T, status: number = 200): Result<T> {
  // 先使用 Mock.mock 生成元数据，然后直接设置 data，避免 data 被 mock 处理
  const result = Mock.mock({
    requestId: '@guid',
    requestTime: '@datetime("yyyy-MM-dd HH:mm:ss")',
    status,
    errorCode: status === 200 ? '' : '@word(5,10)',
    errorMessage: status === 200 ? '' : '@cword(5,15)',
  }) as Result<T>;
  
  // 直接设置 data，不经过 Mock.mock 处理
  result.data = data;
  
  return result;
}

/**
 * 生成符合 <%= table.camelName %> 类型的 Mock 数据模板
 */
function get<%= table.camelName %>Template(overrides: Partial<any> = {}): any {
  return {
    'id|+1': 1,
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    <% if (col.type === 'string') { -%>
    '<%= col.camelName %>|1': ['@word(3,10)', <% if (col.nullable) { %>null<% } else { %>'@word(3,10)'<% } %>],
    <% } else if (col.type === 'number') { -%>
    '<%= col.camelName %>': '@integer(1, 100)',
    <% } else { -%>
    '<%= col.camelName %>': '@word(3,10)',
    <% } -%>
<% }); -%>
    version: '@integer(1, 100)',
    createTime: '@datetime("yyyy-MM-dd HH:mm:ss")',
    updateTime: '@datetime("yyyy-MM-dd HH:mm:ss")',
    ...overrides,
  };
}

/**
 * <%= table.title %>相关的 Mock 数据映射
 */
export const <%= table.camelName %>MockDataMap: MockDataMap = {
  // GET <%= table.routePath %> - 根据条件查询列表
  '<%= table.routePath %>': (config: AxiosRequestConfig) => {
    const query = config.params || {};
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    const <%= col.camelName %> = query?.<%= col.camelName %>;
<% }); -%>

    const count = 15;

    const list: any[] = [];
    for (let i = 0; i < count; i++) {
      const item = Mock.mock(
        get<%= table.camelName %>Template({
          id: i + 1,
        }),
      );
      list.push(item);
    }

    let filteredList = list;
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    if (<%= col.camelName %>) {
      filteredList = filteredList.filter((item: any) => {
        <% if (col.type === 'string') { -%>
        return item.<%= col.camelName %> && item.<%= col.camelName %>.includes(<%= col.camelName %>);
        <% } else { -%>
        return item.<%= col.camelName %> === <%= col.camelName %>;
        <% } -%>
      });
    }
<% }); -%>

    return createResult(filteredList);
  },

  // GET <%= table.routePath %>/list - 根据条件查询列表（兼容接口）
  '<%= table.routePath %>/list': (config: AxiosRequestConfig) => {
    const query = config.params || {};
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    const <%= col.camelName %> = query?.<%= col.camelName %>;
<% }); -%>

    const count = 15;

    const list: any[] = [];
    for (let i = 0; i < count; i++) {
      const item = Mock.mock(
        get<%= table.camelName %>Template({
          id: i + 1,
        }),
      );
      list.push(item);
    }

    let filteredList = list;
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    if (<%= col.camelName %>) {
      filteredList = filteredList.filter((item: any) => {
        <% if (col.type === 'string') { -%>
        return item.<%= col.camelName %> && item.<%= col.camelName %>.includes(<%= col.camelName %>);
        <% } else { -%>
        return item.<%= col.camelName %> === <%= col.camelName %>;
        <% } -%>
      });
    }
<% }); -%>

    return createResult(filteredList);
  },

  // GET <%= table.routePath %>/page - 根据条件分页查询
  '<%= table.routePath %>/page': (config: AxiosRequestConfig) => {
    const query = config.params || {};
    const pageNum = parseInt(query?.pageNum || query?.page || '1', 10);
    const pageSize = parseInt(query?.pageSize || query?.size || '10', 10);
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
    const <%= col.camelName %> = query?.query?.<%= col.camelName %> || query?.<%= col.camelName %>;
<% }); -%>

    const total = 50;
    const count = Math.min(pageSize, total - (pageNum - 1) * pageSize);
    const template: any = {
      [`records|${count}`]: [get<%= table.camelName %>Template()],
    };

    const result = Mock.mock(template);

    // 计算总页数
    const totalPages = Math.ceil(total / pageSize);

    const pageData = {
      pageNum,
      pageSize,
      total,
      totalPages,
      records: result.records,
    };

    return createResult(pageData);
  },

  // POST <%= table.routePath %>/save - 保存（新增或更新）
  '<%= table.routePath %>/save': (config: AxiosRequestConfig) => {
    const payload = config.data || {};
    const isUpdate = payload.id !== undefined && payload.id !== null;
    
    // 如果是更新，使用传入的 id；如果是新增，生成新 id
    const id = isUpdate ? payload.id : Mock.Random.integer(1000, 9999);
    
    // 生成完整的<%= table.title %>数据
    const <%= table.camelName %>Item = Mock.mock(
      get<%= table.camelName %>Template({
        id,
<% table.businessColumns.filter(col => !col.isDeleteFlag).forEach(col => { -%>
        <%= col.camelName %>: payload.<%= col.camelName %> !== undefined ? payload.<%= col.camelName %> : <% if (col.nullable) { %>null<% } else if (col.type === 'string') { %>'@word(3,10)'<% } else { %>'@integer(1, 100)'<% } %>,
<% }); -%>
        updateTime: '@datetime("yyyy-MM-dd HH:mm:ss")',
        createTime: isUpdate ? '@datetime("yyyy-MM-dd HH:mm:ss")' : '@datetime("yyyy-MM-dd HH:mm:ss")',
      }),
    );
    
    return createResult(<%= table.camelName %>Item);
  },

  // DELETE <%= table.routePath %>/:id - 删除
  '<%= table.routePath %>/:id': (config: AxiosRequestConfig) => {
    const deletedRows = 1;
    return createResult(deletedRows);
  },
};

// 模块加载时自动注册到 mockManager
mockManager.registerAll(<%= table.camelName %>MockDataMap);

